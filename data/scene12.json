        { "type": "setCharacterImage", "target": "veronica", "image": "assets/characters/veronica-faceup.png" },
        { "type": "dialogue", "speaker": "Veronica", "text": "Oh, hey [Hero]! Didn't see you there!" },
        { "type": "dialogue", "speaker": "Veronica", "text": "It's been a while... I guess we've never really talked one on one, have we?" },
        { "type": "dialogue", "speaker": "Hero", "text": "I-" },
        { "type": "dialogue", "speaker": "Veronica", "text": "How have you been? Personally, I love my life. Some would say I'm thriving." },
        { "type": "pause", "duration": 500 },
        { "type": "dialogue", "speaker": "Hero", "text": "..." },
        { "type": "dialogue", "speaker": "Veronica", "text": "But it has been feeling pretty desolate around here lately. I think everyone is going crazy or something." },
        { "type": "dialogue", "speaker": "Hero", "text": "Mhm." },
        { "type": "dialogue", "speaker": "Veronica", "text": "You know how it is in this town, when part of our routine is changed everyone gets unsettled. It's easy for things to feel like their falling apart when no one's around to pick up the pieces. Maybe if you hadn't up and disappeared like you did..." },
        { "type": "pause", "duration": 1000 },
        { "type": "dialogue", "speaker": "Veronica", "text": "I forgive you though, I have a generous spirit." },
        { "type": "pause", "duration": 500 },
        { "type": "dialogue", "speaker": "Veronica", "text": "...or so people say!" },
        { "type": "pause", "duration": 500 },
        { "type": "dialogue", "speaker": "Hero", "text": "It's pretty dirty in here." },
        { "type": "dialogue", "speaker": "Veronica", "text": "Oh? Yeah, I guess it is... I hadn't noticed." },
        { "type": "dialogue", "speaker": "Veronica", "text": "Anyway, what can I get for you?" },
        { "type": "dialogue", "speaker": "Hero", "text": "I'd like some flowers." },
        { "type": "dialogue", "speaker": "Veronica", "text": "Sure, have a look around." },
        { "type": "transition" }
    ]
