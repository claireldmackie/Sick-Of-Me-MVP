        { "type": "dialogue", "speaker": "Erma", "text": "Right..." },
        { "type": "dialogue", "speaker": "Erma", "text": "You know, you've really let this place go. We all have responsibilities to uphold, even if we don't feel like it. Everyone in town is doing their best, you could put in more effort to help." },
        { "type": "dialogue", "speaker": "Hero", "text": "..." },
